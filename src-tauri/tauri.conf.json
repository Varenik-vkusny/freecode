{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "freecode",
  "version": "0.2.6",
  "identifier": "com.nikita.freecode",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:47821",
    "beforeDevCommand": "npm run dev --prefix frontend -- -p 47821",
    "beforeBuildCommand": "npm run build --prefix frontend"
  },
  "app": {
    "windows": [
      {
        "title": "FreeCode",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": [
      "bin/server"
    ],
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
